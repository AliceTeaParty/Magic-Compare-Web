generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Case {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  subtitle     String?  @default("")
  summary      String   @default("")
  tagsJson     String   @default("[]")
  status       String
  coverAssetId String?
  publishedAt  DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  groups       Group[]
  uploadJobs   GroupUploadJob[]
}

model Group {
  id          String  @id @default(cuid())
  caseId      String
  slug        String
  publicSlug  String? @unique
  title       String
  description String  @default("")
  order       Int
  defaultMode String
  isPublic    Boolean @default(false)
  tagsJson    String  @default("[]")
  storageRoot String
  lastUploadInputHash String?
  case        Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  frames      Frame[]
  uploadJobs  GroupUploadJob[]

  @@unique([caseId, slug])
  @@index([caseId, order])
}

model Frame {
  id       String  @id @default(cuid())
  groupId  String
  title    String
  caption  String  @default("")
  order    Int
  isPublic Boolean @default(true)
  storagePrefix String
  group    Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assets   Asset[]

  @@index([groupId, order])
}

model Asset {
  id               String  @id @default(cuid())
  frameId          String
  kind             String
  label            String
  imageUrl         String
  thumbUrl         String
  width            Int
  height           Int
  note             String  @default("")
  isPublic         Boolean @default(true)
  isPrimaryDisplay Boolean @default(false)
  frame            Frame   @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@index([frameId])
}

model GroupUploadJob {
  id                 String           @id @default(cuid())
  caseId             String
  groupId            String
  inputHash          String
  snapshotJson       String
  status             String
  expectedFrameCount Int
  committedFrameCount Int            @default(0)
  expiresAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  case               Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  group              Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  frameJobs          FrameUploadJob[]

  @@index([groupId, status, updatedAt])
}

model FrameUploadJob {
  id                String         @id @default(cuid())
  groupUploadJobId  String
  frameOrder        Int
  frameSnapshotJson String
  preparedAssetsJson String        @default("")
  pendingPrefix     String?
  status            String
  committedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  groupUploadJob    GroupUploadJob @relation(fields: [groupUploadJobId], references: [id], onDelete: Cascade)

  @@unique([groupUploadJobId, frameOrder])
  @@index([groupUploadJobId, status])
}
