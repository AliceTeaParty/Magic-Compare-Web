{
  "name": "@magic-compare/public-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --tsconfig ../../tsconfig.base.json ../../scripts/sync-published.ts && next dev",
    "build": "tsx --tsconfig ../../tsconfig.base.json ../../scripts/sync-published.ts && next build && tsx --tsconfig ../../tsconfig.base.json ../../scripts/write-public-route-aliases.ts",
    "start": "serve out --listen 3001",
    "typecheck": "next build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@magic-compare/compare-core": "workspace:*",
    "@magic-compare/content-schema": "workspace:*",
    "@magic-compare/shared-utils": "workspace:*",
    "@magic-compare/ui": "workspace:*",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "motion": "^12.23.24",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serve": "^14.2.4",
    "zod": "^4.3.6"
  }
}
