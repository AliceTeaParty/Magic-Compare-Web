# Magic Compare uploader 本地配置
# 可以复制到 uploader 工作目录，也可以让 CLI 在第一次运行时自动生成。

# internal-site 首页地址，用来推断 API 地址并判断远端访问策略。
MAGIC_COMPARE_SITE_URL=http://localhost:3000

# 可选：显式覆盖 group-upload-start 接口地址。
# 留空时会从 MAGIC_COMPARE_SITE_URL 自动拼出 /api/ops/group-upload-start。
MAGIC_COMPARE_API_URL=

# 只有在 MAGIC_COMPARE_SITE_URL 指向非本地 internal-site 时才需要填写。
MAGIC_COMPARE_CF_ACCESS_CLIENT_ID=
MAGIC_COMPARE_CF_ACCESS_CLIENT_SECRET=
