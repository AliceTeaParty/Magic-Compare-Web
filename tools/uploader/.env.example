# Magic Compare uploader local configuration
# Copy this into an uploader work directory, or let the CLI create that file for you.

# Internal site homepage used for API derivation and remote access policy checks.
MAGIC_COMPARE_SITE_URL=http://localhost:3000

# Optional explicit import endpoint override.
# Leave blank to derive /api/ops/import-sync from MAGIC_COMPARE_SITE_URL.
MAGIC_COMPARE_API_URL=

# S3-compatible internal asset storage used by the Python uploader.
MAGIC_COMPARE_S3_BUCKET=magic-compare-assets
MAGIC_COMPARE_S3_REGION=us-east-1
MAGIC_COMPARE_S3_ENDPOINT=http://localhost:9000
MAGIC_COMPARE_S3_ACCESS_KEY_ID=rustfsadmin
MAGIC_COMPARE_S3_SECRET_ACCESS_KEY=rustfsadmin
MAGIC_COMPARE_S3_FORCE_PATH_STYLE=true
MAGIC_COMPARE_S3_INTERNAL_PREFIX=internal-assets

# Required only when MAGIC_COMPARE_SITE_URL points to a non-local internal site.
MAGIC_COMPARE_CF_ACCESS_CLIENT_ID=
MAGIC_COMPARE_CF_ACCESS_CLIENT_SECRET=
