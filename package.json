{
  "name": "magic-compare-web",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @magic-compare/internal-site build && pnpm --filter @magic-compare/public-site build",
    "dev:internal": "pnpm --filter @magic-compare/internal-site dev",
    "dev:public": "pnpm --filter @magic-compare/public-site dev",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "sync:published": "node scripts/sync-published.mjs",
    "public:export": "tsx scripts/export-public.ts",
    "public:deploy": "tsx scripts/deploy-public.ts",
    "docker:build:internal": "docker build -f docker/internal-site.Dockerfile -t magic-compare/internal-site .",
    "db:generate": "pnpm --filter @magic-compare/internal-site db:generate",
    "db:push": "pnpm --filter @magic-compare/internal-site db:push",
    "db:seed": "pnpm --filter @magic-compare/internal-site db:seed",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.49.1"
  }
}
