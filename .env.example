# Magic Compare shared runtime configuration

# Internal site homepage protected by Cloudflare Access.
MAGIC_COMPARE_SITE_URL=http://localhost:3000
# Optional explicit import endpoint. Leave blank to derive from site URL.
MAGIC_COMPARE_API_URL=

# Internal site runtime (host/local development)
DATABASE_URL=file:./dev.db
MAGIC_COMPARE_HIDE_DEMO=false
MAGIC_COMPARE_PUBLISHED_ROOT=
MAGIC_COMPARE_PUBLIC_EXPORT_DIR=
MAGIC_COMPARE_FOOTER_YEAR_START=2026
MAGIC_COMPARE_FOOTER_AUTHOR=Magic Compare
MAGIC_COMPARE_FOOTER_JOIN_US_LABEL=Join us
MAGIC_COMPARE_FOOTER_JOIN_US_URL=

# Internal site runtime (Docker persistent volume)
MAGIC_COMPARE_DOCKER_DATABASE_URL=file:/app/data/sqlite/internal-site.db
MAGIC_COMPARE_INTERNAL_SITE_IMAGE=ghcr.io/aliceteaparty/magic-compare-web:main

# S3-compatible storage for internal assets (host/local tools)
MAGIC_COMPARE_S3_BUCKET=magic-compare-assets
MAGIC_COMPARE_S3_REGION=us-east-1
MAGIC_COMPARE_S3_ENDPOINT=http://localhost:9000
MAGIC_COMPARE_S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/magic-compare-assets
MAGIC_COMPARE_S3_ACCESS_KEY_ID=rustfsadmin
MAGIC_COMPARE_S3_SECRET_ACCESS_KEY=rustfsadmin
MAGIC_COMPARE_S3_FORCE_PATH_STYLE=true
MAGIC_COMPARE_S3_INTERNAL_PREFIX=internal-assets

# S3-compatible storage endpoint inside Docker network
MAGIC_COMPARE_DOCKER_S3_ENDPOINT=http://rustfs:9000

# RustFS local container tuning
# Console is optional and disabled by default to save memory.
MAGIC_COMPARE_RUSTFS_CONSOLE_ENABLE=false
MAGIC_COMPARE_RUSTFS_S3_PORT=9000
MAGIC_COMPARE_RUSTFS_CONSOLE_PORT=9001
MAGIC_COMPARE_RUSTFS_ADDRESS=0.0.0.0:9000
MAGIC_COMPARE_RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
MAGIC_COMPARE_RUSTFS_LOG_LEVEL=warn
MAGIC_COMPARE_RUSTFS_MALLOC_ARENA_MAX=2
MAGIC_COMPARE_RUSTFS_MEM_LIMIT=512m
MAGIC_COMPARE_RUSTFS_CPUS=1.0
MAGIC_COMPARE_RUSTFS_TMPFS_SIZE=64m
MAGIC_COMPARE_RUSTFS_LOG_MAX_SIZE=10m
MAGIC_COMPARE_RUSTFS_LOG_MAX_FILE=3

# Cloudflare Access for uploader / automation
MAGIC_COMPARE_CF_ACCESS_TOKEN=
MAGIC_COMPARE_CF_ACCESS_CLIENT_ID=
MAGIC_COMPARE_CF_ACCESS_CLIENT_SECRET=

# Cloudflare Pages direct upload
MAGIC_COMPARE_CF_PAGES_PROJECT_NAME=
MAGIC_COMPARE_CF_PAGES_BRANCH=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
