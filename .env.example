# Magic Compare shared runtime configuration

# Internal site local dev
# Used by pnpm dev:internal and host-side Node scripts outside Docker.
# Leave the path-based defaults unless you want custom host-local storage.
# -------------------------------------------------------------------

# Host-local SQLite database path for local development.
DATABASE_URL=file:./dev.db

# Set true in production if the built-in demo should be hidden.
MAGIC_COMPARE_HIDE_DEMO=false

# Published manifest root on the host.
# Leave blank to use the repository default path.
MAGIC_COMPARE_PUBLISHED_ROOT=

# Static public export output on the host.
# Leave blank to use the repository default path.
MAGIC_COMPARE_PUBLIC_EXPORT_DIR=

# Shared footer configuration for internal/public site layouts.
# Leave blank to accept the code/docker defaults.
MAGIC_COMPARE_FOOTER_YEAR_START=
MAGIC_COMPARE_FOOTER_AUTHOR=
MAGIC_COMPARE_FOOTER_JOIN_US_LABEL=
MAGIC_COMPARE_FOOTER_JOIN_US_URL=

# -------------------------------------------------------------------
# Internal site Docker / server runtime
# Used by docker-compose and server-side container runtime.
# Keep these defaults unless your server mount paths or image source differ.
# -------------------------------------------------------------------

# SQLite path inside the internal-site container.
MAGIC_COMPARE_DOCKER_DATABASE_URL=file:/app/data/sqlite/internal-site.db

# Base docker-compose image source.
# The base compose file pulls this GHCR image by default.
MAGIC_COMPARE_INTERNAL_SITE_IMAGE=ghcr.io/aliceteaparty/magic-compare-web:main

# Host port mapped to the internal-site container's fixed port 3000.
# Change this when 3000 is already occupied on the host.
MAGIC_COMPARE_INTERNAL_SITE_HOST_PORT=3000

# Optional host bind mount for /app/data inside internal-site containers.
# Leave blank to use the default Docker named volume `internal-data`.
# Set it to a host path such as ./docker-data/internal-data when you want files visible on disk.
MAGIC_COMPARE_INTERNAL_DATA_MOUNT=

# -------------------------------------------------------------------
# Website/server S3 image storage
# Used by internal-site, public export, and local Node-side scripts.
# The uploader keeps its own template in tools/uploader/.env.example on purpose.
# -------------------------------------------------------------------

# Bucket that stores source images, thumbnails, and generated heatmaps.
MAGIC_COMPARE_S3_BUCKET=magic-compare-assets
MAGIC_COMPARE_S3_REGION=us-east-1

# Host-visible S3 endpoint for website-side scripts running on the macOS host.
MAGIC_COMPARE_S3_ENDPOINT=http://localhost:9000

# Public browser-facing base URL for image delivery.
# Internal/public sites resolve logical /internal-assets/... paths against this URL.
MAGIC_COMPARE_S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/magic-compare-assets

MAGIC_COMPARE_S3_ACCESS_KEY_ID=rustfsadmin
MAGIC_COMPARE_S3_SECRET_ACCESS_KEY=rustfsadmin
MAGIC_COMPARE_S3_FORCE_PATH_STYLE=true
MAGIC_COMPARE_S3_INTERNAL_PREFIX=internal-assets

# -------------------------------------------------------------------
# Docker-only S3 endpoint
# Used only by containers on the Docker network.
# Do not point host-side tools at this value.
# -------------------------------------------------------------------

# Container-network endpoint for internal-site and rustfs-init.
# Docker containers cannot use localhost here because that would point back to themselves.
MAGIC_COMPARE_DOCKER_S3_ENDPOINT=http://rustfs:9000

# Optional host bind mount for the local object-storage data directory.
# Leave blank to use the default Docker named volume `rustfs-data`.
# Set it to a host path such as ./docker-data/rustfs when you want bucket files persisted on disk.
MAGIC_COMPARE_RUSTFS_DATA_MOUNT=

# -------------------------------------------------------------------
# Local object storage container
# No per-container tuning knobs are exposed here on purpose.
# If you really need to change local MinIO ports or runtime flags, edit docker-compose.yml.
# -------------------------------------------------------------------

# Cloudflare Pages deploy
# Used only when internal-site exports and deploys the public site to Pages.
# Fill these on a deployment host or CI environment that performs deploys.
# -------------------------------------------------------------------

# Optional public site base URL for "open published page" links.
# If set, internal-site links open this custom domain instead of *.pages.dev.
MAGIC_COMPARE_PUBLIC_SITE_BASE_URL=

MAGIC_COMPARE_CF_PAGES_PROJECT_NAME=
MAGIC_COMPARE_CF_PAGES_BRANCH=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
